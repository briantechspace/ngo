# Server Configuration
PORT=5055
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ngo_db
DATABASE_SSL=false
USE_MOCK_DB=false

# Cloudinary Integration (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack Integration (Donations)
# Note: For testing, use your Paystack Test keys (starting with pk_test_ and sk_test_)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key

# Admin Dashboard Authentication Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=eco_admin_2026
JWT_SECRET=generate_a_random_secure_secret_key_here

